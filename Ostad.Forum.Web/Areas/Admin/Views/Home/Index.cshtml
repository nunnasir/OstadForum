@{
    ViewData["Title"] = "Admin Dashboard";
}

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h1 class="mb-4">Admin Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Categories</h5>
                <p class="card-text">Manage forum categories.</p>
                <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-primary">Manage Categories</a>
            </div>
        </div>
    </div>
</div>

