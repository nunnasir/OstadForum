@model Ostad.Forum.Web.Models.HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
}

@* Filter bar - wire functionality later *@
<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end flex-wrap">
            <div class="col-auto">
                <label class="form-label small text-muted mb-0 me-2">Search</label>
                <input type="text" class="form-control form-control-sm" id="filterSearch" placeholder="Search questions..." aria-label="Search questions" style="min-width: 180px;" />
            </div>
            <div class="col-auto">
                <label class="form-label small text-muted mb-0 me-2">Category</label>
                <select class="form-select form-select-sm" style="min-width: 140px;" id="filterCategory" aria-label="Filter by category">
                    <option value="">All categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.CategoryId">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small text-muted mb-0 me-2">Tag</label>
                <select class="form-select form-select-sm" style="min-width: 120px;" id="filterTag" aria-label="Filter by tag">
                    <option value="">All tags</option>
                    @foreach (var t in Model.Tags)
                    {
                        <option value="@t.TagId">@t.Name</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small text-muted mb-0 me-2">Sort</label>
                <select class="form-select form-select-sm" style="min-width: 160px;" id="filterSort" aria-label="Sort order">
                    <option value="newest">Newest first</option>
                    <option value="oldest">Oldest first</option>
                    <option value="most-answers">Most answers</option>
                    <option value="most-views">Most views</option>
                </select>
            </div>
            <div class="col-auto ms-auto">
                <button type="button" class="btn btn-primary btn-sm" id="filterApply">Apply</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="filterClear">Clear</button>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @* Main content *@
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h4 mb-0 fw-bold text-dark">Latest Questions</h1>
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a class="btn btn-primary rounded-pill px-4 shadow-sm" asp-controller="Question" asp-action="Create">
                    Ask Question
                </a>
            }
            else
            {
                <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Account" asp-action="Login">
                    Login to ask a question
                </a>
            }
        </div>

        @if (!Model.Questions.Any())
        {
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body text-center py-5">
                    <p class="text-muted mb-0">No questions have been posted yet.</p>
                    @if (!(User.Identity?.IsAuthenticated ?? false))
                    {
                        <p class="mt-2 mb-0 small">
                            <a asp-controller="Account" asp-action="Login">Login</a> or
                            <a asp-controller="Account" asp-action="Register">register</a> to ask the first question.
                        </p>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var q in Model.Questions)
                {
                    <a asp-controller="Question" asp-action="Details" asp-route-id="@q.QuestionId"
                       class="card border-0 shadow-sm rounded-3 text-decoration-none text-dark question-card">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-auto text-center pe-3">
                                    <div class="rounded-3 bg-light px-3 py-2">
                                        <div class="fw-bold fs-5 text-primary">@q.AnswerCount</div>
                                        <small class="text-muted">answers</small>
                                    </div>
                                </div>
                                <div class="col">
                                    <h5 class="card-title mb-2 fw-semibold">@q.Title</h5>
                                    <p class="card-text text-muted small mb-0">
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary">@q.CategoryName</span>
                                        <span class="ms-2">@q.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                    </p>
                                </div>
                                <div class="col-auto text-end">
                                    <div class="rounded-3 bg-light px-3 py-2">
                                        <div class="fw-bold">@q.ViewCount</div>
                                        <small class="text-muted">views</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    @* Right sidebar *@
    <aside class="col-lg-4">
        <div class="sidebar-sticky">
            @* Categories card *@
            <div class="card shadow-sm rounded-3 mb-4 sidebar-card sidebar-card-categories">
                <div class="card-header border-0 pt-4 pb-3 px-4 sidebar-card-header sidebar-card-header-categories">
                    <h5 class="mb-0 fw-semibold text-white">Categories</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (Model.Categories.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var c in Model.Categories)
                            {
                                <li class="mb-2">
                                    <a href="#" class="d-block py-2 px-3 rounded-2 text-decoration-none text-dark sidebar-link"
                                       data-category-id="@c.CategoryId">
                                        @c.Name
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No categories yet.</p>
                    }
                </div>
            </div>

            @* Tags card *@
            <div class="card shadow-sm rounded-3 sidebar-card sidebar-card-tags">
                <div class="card-header border-0 pt-4 pb-3 px-4 sidebar-card-header sidebar-card-header-tags">
                    <h5 class="mb-0 fw-semibold text-white">Tags</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (Model.Tags.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var t in Model.Tags)
                            {
                                <a href="#" class="badge bg-secondary bg-opacity-10 text-secondary text-decoration-none px-3 py-2 tag-pill"
                                   data-tag-id="@t.TagId">
                                    @t.Name
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No tags yet.</p>
                    }
                </div>
            </div>
        </div>
    </aside>
</div>

<style>
    .question-card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
        transform: translateY(-1px);
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .sidebar-link:hover {
        background-color: rgba(13, 110, 253, 0.08);
        color: var(--bs-primary) !important;
    }
    .tag-pill:hover {
        background-color: rgba(13, 110, 253, 0.15) !important;
        color: var(--bs-primary) !important;
    }
    /* Sidebar cards – colourful heading and border */
    .sidebar-card-categories {
        border: 2px solid #0d6efd;
        border-top: 4px solid #0d6efd;
    }
    .sidebar-card-header-categories {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: #fff;
        border-radius: calc(0.5rem - 2px) calc(0.5rem - 2px) 0 0;
    }
    .sidebar-card-tags {
        border: 2px solid #198754;
        border-top: 4px solid #198754;
    }
    .sidebar-card-header-tags {
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        color: #fff;
        border-radius: calc(0.5rem - 2px) calc(0.5rem - 2px) 0 0;
    }
</style>
